# Django settings
SECRET_KEY=<required>
ADMIN_URL=<required-for-production>
MEDIA_ROOT=<required-for-production>
ALLOWED_HOSTS=<required-for-production>
CSRF_TRUSTED_ORIGINS=<required-for-production>

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# REVIEW: Security (prod toggles)
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# REVIEW Gunicorn (prod)
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# Email (prod): Google Workspace SMTP Relay
# EMAIL_HOST/EMAIL_PORT/EMAIL_USE_TLS default to smtp-relay.gmail.com:587 + TLS;
# only set them here to override (e.g. a staging relay).
# DEFAULT_FROM_EMAIL is required in production (no default) and must be an
# address in the allowed Workspace domain, e.g. "Pathogens Portal <freya_services@scilifelab.se>".
# Leave commented for local dev so the development.py default sender takes effect.
# DEFAULT_FROM_EMAIL=
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USE_TLS=

# Email (dev): mailpit captures local SMTP and shows it at http://localhost:8025/.
# `docker compose up` to start it.
# To route the app through mailpit instead of the console backend, override:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# Use EMAIL_HOST=mailpit if running inside docker compose (the service name resolves on the network).
# EMAIL_HOST=mailpit
# EMAIL_PORT=1025
# EMAIL_USE_TLS=False

# Optional local dev settings

# set to 'true' if you wanna
# use 'graph_models' command
# of 'django-extensions'
with_pygraphviz=false
