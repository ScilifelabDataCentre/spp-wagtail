{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabled": true,
  "enabledManagers": ["dockerfile", "docker-compose", "github-actions", "pep621", "pre-commit"],
  "vulnerabilityAlerts": {
    "vulnerabilityFixStrategy": "highest"
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "non-major dependencies",
      "description": "Group all non-major updates together and schedule them to run at 07:00 on every Tuesday.",
      "schedule": ["* 7 * * TUE"]
    }
  ]
}
